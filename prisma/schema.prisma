datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  dsaProblems   DSAProblem[]
  contests      Contest[]
  projects      Project[]
  resumes       Resume[]
  streaks       Streak[]
  questions     QuestionBank[]
  mockSessions  MockSession[]
  roadmaps      Roadmap[]
  createdAt     DateTime  @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model DSAProblem {
  id         String     @id @default(cuid())
  title      String
  difficulty Difficulty
  topic      Topic
  status     Status     @default(TODO)
  notes      String?    @db.Text
  solvedAt   DateTime?
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Status {
  TODO
  SOLVING
  DONE
  REVISIT
}

enum Topic {
  ARRAYS
  STRINGS
  LINKED_LISTS
  TREES
  GRAPHS
  DYNAMIC_PROGRAMMING
  BACKTRACKING
  GREEDY
  MATH
  BIT_MANIPULATION
}

model Contest {
  id                String    @id @default(cuid())
  platform          Platform
  contestName       String
  date              DateTime
  rank              Int?
  totalParticipants Int?
  problemsSolved    Int?
  ratingChange      Int?
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

enum Platform {
  LEETCODE
  CODEFORCES
  CODECHEF
  OTHER
}

model Project {
  id          String        @id @default(cuid())
  title       String
  description String?       @db.Text
  techStack   String[]
  githubUrl   String?
  liveUrl     String?
  status      ProjectStatus @default(IDEA)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum ProjectStatus {
  IDEA
  IN_PROGRESS
  COMPLETED
  DEPLOYED
}

model Resume {
  id        String   @id @default(cuid())
  version   String
  label     String?
  fileUrl   String
  notes     String?  @db.Text
  isActive  Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Streak {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model QuestionBank {
  id         String   @id @default(cuid())
  question   String   @db.Text
  hint       String?  @db.Text
  topic      String
  difficulty String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model MockSession {
  id         String   @id @default(cuid())
  transcript Json
  score      Int?
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Roadmap {
  id                String        @id @default(cuid())
  overview          String        @db.Text
  company           String
  role              String
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  weeks             RoadmapWeek[]
}

model RoadmapWeek {
  id                String   @id @default(cuid())
  weekNumber        Int
  theme             String
  dsaTopics         String[]
  problemCount      Int
  systemDesignTopic String
  milestone         String
  isCompleted       Boolean  @default(false)
  roadmapId         String
  roadmap           Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
}
